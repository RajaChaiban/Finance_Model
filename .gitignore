# =============================================================================
# .gitignore — keep README.md + architecture.md + main code only
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv
pip-log.txt
pip-delete-this-directory.txt
.coverage
.coverage.*
.pytest_cache/
htmlcov/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints
*.ipynb
.colab

# --- Node / Vite / Frontend build artifacts ---
node_modules/
dist/
build/
.vite/
frontend/.vite/
frontend/dist/
frontend/node_modules/
playwright-report/
test-results/

# --- IDE / editor ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db

# --- Secrets — NEVER commit .env files ---
.env
.env.*
!.env.example
*.env
*.env.local

# --- Logs / caches ---
*.log
.cache/

# --- Tabular data dumps ---
*.csv
*.parquet
*.pkl

# --- Runtime ChromaDB vector stores (seed corpus IS tracked) ---
data/market_intel/
frontend/data/market_intel/

# --- Local agent / tooling state ---
.claude/
.superpowers/
.stitch-project.json
.design-argopilot-new/
.playwright-mcp/

# --- Root-level screenshots / images (clutter) ---
/*.png

# --- Reports / one-off outputs ---
reports/
analysis_output.txt

# --- Local notes / research / drafts ---
raja_notes/
research/
docs/

# --- Local-only docs (keep README.md + architecture.md only) ---
CLAUDE.md
SETUP.md
QUANTLIB_INTEGRATION.md
SOLVER_COMPONENT.md
README_structured_pricing.md
README_ESMM.md
architecture_ESMM.md
ESMM_LAB.md
ARGOPILOT_STRUCTURING_EXTENSIONS.md

# --- Orphan / one-off files at repo root ---
Knockout_Option_Pricer_SP500.ipynb
ko_analysis.py
test_solver.py

# --- Default Vite scaffold README (not the project README) ---
frontend/README.md

# --- Safety: prevent any cross-project contamination ---
../
../.git/
../.gitignore
