# Agent layer secrets — copy to .env (gitignored) and fill in.
#
# Required for the LLM-driven agents (Intake, Strategist, Narrator, Validator):
# Get an API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional — Phase 2 (market regime). Without it, regime fields use yfinance fallbacks.
FRED_API_KEY=

# Optional — Phase 5 (real vol surfaces). Without it, surface comes from yfinance option chains.
POLYGON_API_KEY=

# ----------------------------------------------------------------------------
# Model selection (Gemini)
# ----------------------------------------------------------------------------
# Two tiers. Smart = IP-bearing agents (Strategist, Narrator). Fast = parsers
# (Intake, Validator, Scenario commentary). Per-agent overrides below.
#
# Valid model IDs (Q1 2026):
#   gemini-3-pro-preview     — smartest (Google's flagship reasoning, preview)
#   gemini-3-flash-preview   — cheaper Gemini 3
#   gemini-2.5-pro           — Gemini 2.5 reasoning (GA)
#   gemini-2.5-flash         — balanced (GA)
#   gemini-2.5-flash-lite    — cheapest (GA)
AGENT_MODEL_SMART=gemini-3-pro-preview
AGENT_MODEL_FAST=gemini-2.5-flash

# Per-agent overrides (uncomment to override the tier above).
# AGENT_MODEL_STRATEGIST=gemini-3-pro-preview
# AGENT_MODEL_NARRATOR=gemini-3-pro-preview
# AGENT_MODEL_INTAKE=gemini-2.5-flash
# AGENT_MODEL_VALIDATOR=gemini-2.5-flash
# AGENT_MODEL_SCENARIO=gemini-2.5-flash

# Demo on-stage failsafe: set to 1 to make the orchestrator replay canned LLM
# responses from tests/fixtures/demo_replay.json. Used for offline demos.
DEMO_REPLAY=0

# Per-session cost ceiling in USD (kill-switch for runaway sessions). Default 0.50.
AGENT_COST_CEILING_USD=0.50
