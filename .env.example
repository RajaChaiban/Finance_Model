# Agent layer secrets — copy to .env (gitignored) and fill in.
#
# Required for the LLM-driven agents (Intake, Strategist, Narrator, Validator):
# Get an API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional — Phase 2 (market regime). Without it, regime fields use yfinance fallbacks.
FRED_API_KEY=

# Optional — Phase 5 (real vol surfaces). Without it, surface comes from yfinance option chains.
POLYGON_API_KEY=

# Optional — OpenRouter (LLM-router; aggregates Anthropic / OpenAI / Google /
# Meta / Mistral models behind one OpenAI-compatible API). Used by the MI/RAG
# synthesis layer when MARKET_INTEL_LLM_PROVIDER=openrouter. Sign up at
# https://openrouter.ai — pay-as-you-go, no minimum.
OPENROUTER_API_KEY=

# ----------------------------------------------------------------------------
# Model selection (Gemini)
# ----------------------------------------------------------------------------
# Two tiers. Smart = IP-bearing agents (Strategist, Narrator). Fast = parsers
# (Intake, Validator, Scenario commentary). Per-agent overrides below.
#
# Valid model IDs (Q1 2026):
#   gemini-3-pro-preview     — smartest (Google's flagship reasoning, preview)
#   gemini-3-flash-preview   — cheaper Gemini 3
#   gemini-2.5-pro           — Gemini 2.5 reasoning (GA)
#   gemini-2.5-flash         — balanced (GA)
#   gemini-2.5-flash-lite    — cheapest (GA)
AGENT_MODEL_SMART=gemini-3-pro-preview
AGENT_MODEL_FAST=gemini-2.5-flash

# Per-agent overrides (uncomment to override the tier above).
# AGENT_MODEL_STRATEGIST=gemini-3-pro-preview
# AGENT_MODEL_NARRATOR=gemini-3-pro-preview
# AGENT_MODEL_INTAKE=gemini-2.5-flash
# AGENT_MODEL_VALIDATOR=gemini-2.5-flash
# AGENT_MODEL_SCENARIO=gemini-2.5-flash

# Demo on-stage failsafe: set to 1 to make the orchestrator replay canned LLM
# responses from tests/fixtures/demo_replay.json. Used for offline demos.
DEMO_REPLAY=0

# Per-session cost ceiling in USD (kill-switch for runaway sessions). Default 0.50.
AGENT_COST_CEILING_USD=0.50

# ----------------------------------------------------------------------------
# Market-intelligence (RAG) layer — src/agents/market_intelligence.py
# ----------------------------------------------------------------------------
# Master flag. Set to 0 to skip the RAG layer entirely (agents fall back to
# pure-QuantLib behaviour, no MI calls, no citations in the memo).
MARKET_INTEL_ENABLED=1

# Persist directory for the local Chroma store. Created on first run.
MARKET_INTEL_PERSIST_DIR=./data/market_intel

# Chroma collection name (free-form).
MARKET_INTEL_COLLECTION=market-intelligence

# Sentence-transformers model used for embeddings. Default = BAAI/bge-base-en-v1.5
# (768-dim, top-tier MTEB retrieval, ~440MB on first use). Lighter alternative:
# sentence-transformers/all-MiniLM-L6-v2 (384-dim, ~80MB).
# WARNING: switching this dim invalidates an existing Chroma store — wipe
# MARKET_INTEL_PERSIST_DIR before re-seeding.
MARKET_INTEL_EMBEDDINGS_MODEL=BAAI/bge-base-en-v1.5

# Optional override for the LLM tier the MI prompts use. Defaults to the
# fast-tier model (gemini-2.5-flash).
# AGENT_MODEL_MARKET_INTEL=gemini-2.5-flash

# MI synthesis-LLM provider: "gemini" (default, routes through the same
# LLMClient the agents use — keeps cost-tracking + DEMO_REPLAY) OR
# "openrouter" (routes via openrouter_adapter — useful when Gemini is
# quota-blocked or you want to pick a different model per session).
MARKET_INTEL_LLM_PROVIDER=gemini

# OpenRouter model id when provider=openrouter. Provider/model form.
# Examples:
#   anthropic/claude-opus-4-7      — strongest, costliest
#   anthropic/claude-haiku-4-5     — fast + cheap (default)
#   openai/gpt-5
#   google/gemini-3-pro-preview
#   meta-llama/llama-3.3-70b-instruct
MARKET_INTEL_OPENROUTER_MODEL=anthropic/claude-haiku-4-5

# Optional headers OpenRouter uses for rankings/leaderboard attribution.
# Free-form. Can be left blank.
# MARKET_INTEL_OPENROUTER_REFERER=https://your-app.example.com
# MARKET_INTEL_OPENROUTER_TITLE=Vol Desk
